# General
APP_ENV=local
LOG_LEVEL=INFO
TZ=Asia/Seoul

# FastAPI
API_HOST=127.0.0.1
API_PORT=8000

# TradingView webhook validation
TRADINGVIEW_WEBHOOK_SECRET=replace-with-local-secret

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DRY_RUN=true

# Event logging
EVENT_LOG_DIR=data/events

# Research note drafts
ENABLE_RESEARCH_NOTES=true
RESEARCH_NOTE_DIR=content/research/drafts

# Broker or exchange credentials
# Keep real values only in an ignored .env file or system environment.
BROKER_NAME=paper
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ACCOUNT_ID=

# Trading safety defaults
TRADING_MODE=paper
MAX_POSITION_NOTIONAL=
MAX_DAILY_LOSS=
ENABLE_LIVE_TRADING=false
